{
    "name": "company/auth-client",
    "version": "1.0.3",
    "description": "Client integration for Company centralized authentication.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/support": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Company\\AuthClient\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Company\\AuthClient\\AuthClientServiceProvider"
            ],
            "aliases": {
                "SSOAuth": "Company\\AuthClient\\Facades\\SSOAuth"
            }
        }
    }
}
